    CategoryTheory.HasWeakSheafify ((J.over c).over Z) AddCommGrpCat]
  [∀ (c : C) (Z : CategoryTheory.Over c),
    ((J.over c).over Z).WEqualsLocallyBijective AddCommGrpCat]

omit [CategoryTheory.HasWeakSheafify J AddCommGrpCat]
  [J.WEqualsLocallyBijective AddCommGrpCat]
  [∀ (c : C) (Z : CategoryTheory.Over c),
    CategoryTheory.HasWeakSheafify ((J.over c).over Z) AddCommGrpCat]
  [∀ (c : C) (Z : CategoryTheory.Over c),
    ((J.over c).over Z).WEqualsLocallyBijective AddCommGrpCat] in
/-- Being of finite type is invariant under isomorphism of sheaves of modules. -/
lemma SheafOfModules.IsFiniteType.of_iso {M N : SheafOfModules.{u} R} (e : M ≅ N)
    [M.IsFiniteType] : N.IsFiniteType := by
  obtain ⟨D, hD⟩ := SheafOfModules.IsFiniteType.exists_localGeneratorsData M
  refine ⟨⟨⟨D.I, D.X, D.coversTop,
    fun i ↦ (D.generators i).ofEpi (e.hom.over (D.X i))⟩, ⟨fun i ↦ ⟨?_⟩⟩⟩⟩
  haveI := hD.isFiniteType i
  exact inferInstanceAs (Finite (D.generators i).I)

omit [CategoryTheory.HasWeakSheafify J AddCommGrpCat]
  [J.WEqualsLocallyBijective AddCommGrpCat] in
/-- Coherence is invariant under isomorphism of sheaves of modules. This transport is
used implicitly in the proof of Modules, Lemma 17.12.5 (tag 01BZ), where a module which
is locally isomorphic to a cokernel of a morphism of finite free modules inherits their
coherence. -/
lemma isCoherent_of_iso {M N : SheafOfModules.{u} R} (e : M ≅ N) (hM : IsCoherent M) :
    IsCoherent N := by
  haveI := hM
  constructor
  · haveI := hM.finiteType
    exact SheafOfModules.IsFiniteType.of_iso e
  · intro σ hσ i
    -- pull the given sections of `N` back to sections of `M` along `e.inv`
    let τ : M.LocalSectionData :=
      ⟨σ.I, σ.X, σ.coversTop, fun j ↦ ⟨(σ.sections j).I,
        fun k ↦ SheafOfModules.sectionsMap (e.inv.over (σ.X j)) ((σ.sections j).s k)⟩⟩
    have hker := hM.forall_localSectionData τ (fun j ↦ ⟨(hσ j).finite⟩) i
    have hπ : (τ.sections i).π = (σ.sections i).π ≫ e.inv.over (σ.X i) :=
      (SheafOfModules.freeHomEquiv_symm_comp _ _).symm
    rw [hπ] at hker
    haveI := hker
    exact SheafOfModules.IsFiniteType.of_iso
      (CategoryTheory.Limits.kernelCompMono (σ.sections i).π (e.inv.over (σ.X i)))

end

end

