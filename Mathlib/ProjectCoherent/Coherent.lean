/-- The sheaf of rings `R`, viewed as a module over itself, is of finite type: it is
generated by the single global section `1`. -/
instance SheafOfModules.isFiniteType_unit : (SheafOfModules.unit R).IsFiniteType where
  exists_localGeneratorsData :=
    ⟨(SheafOfModules.unitGeneratingSections (R := R)).localGeneratorsData,
      ⟨fun _ ↦ ⟨inferInstanceAs (Finite PUnit)⟩⟩⟩

