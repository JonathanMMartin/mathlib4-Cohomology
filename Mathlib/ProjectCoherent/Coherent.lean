/-- The unit section `1` generates the sheaf of rings `R` viewed as a module over
itself. -/
noncomputable def SheafOfModules.unitGeneratingSections :
    (SheafOfModules.unit R).GeneratingSections where
  I := PUnit
  s _ := (SheafOfModules.unit R).unitHomEquiv (𝟙 _)
  epi := by
    have h : SheafOfModules.ιFree PUnit.unit ≫ (SheafOfModules.unit R).freeHomEquiv.symm
        (fun _ ↦ (SheafOfModules.unit R).unitHomEquiv (𝟙 _)) =
        𝟙 (SheafOfModules.unit R) := by
      simp [← SheafOfModules.unitHomEquiv_symm_freeHomEquiv_apply]
    exact epi_of_epi_fac h

instance : (SheafOfModules.unitGeneratingSections (R := R)).IsFiniteType where
  finite := inferInstanceAs (Finite PUnit)

