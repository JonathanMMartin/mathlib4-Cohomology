set_option maxHeartbeats 1600000 in
-- Elaborating the `pushforwardPushforwardEquivalence` along the iterated slice
-- equivalence requires unfolding iterated slice sites, which is expensive; the
-- synthesis of `HasWeakSheafify` for the iterated slice site is likewise slow.
set_option synthInstance.maxHeartbeats 400000 in
/-- Local generators data for the restrictions of `M` to a family of objects covering
the terminal object can be glued to local generators data for `M`.
Compare `SheafOfModules.QuasicoherentData.bind`. -/
noncomputable def SheafOfModules.LocalGeneratorsData.bind
    (M : SheafOfModules.{u} R) {ι : Type u} (Y : ι → C) (hY : J.CoversTop Y)
    (D : ∀ i, (M.over (Y i)).LocalGeneratorsData) :
    M.LocalGeneratorsData where
  I := (i : ι) × (D i).I
  X ij := ((D ij.1).X ij.2).left
  coversTop := hY.over fun i ↦ (D i).coversTop
  generators ij :=
    letI e := pushforwardPushforwardEquivalence
      (Over.iteratedSliceEquiv ((D ij.1).X ij.2))
      (S := (R.over _).over _) (R := R.over _) (𝟙 _) (𝟙 _)
      (by ext : 2; exact R.1.map_id _) (by ext : 2; exact R.1.map_id _)
    (((D ij.1).generators ij.2).map e.inverse (.refl _)).ofEpi
      (e.fullyFaithfulFunctor.preimageIso
        (by exact e.counitIso.app ((M.over (Y ij.1)).over ((D ij.1).X ij.2)))).hom

omit [HasWeakSheafify J AddCommGrpCat] [J.WEqualsLocallyBijective AddCommGrpCat]
  [∀ (X : C), HasSheafify (J.over X) AddCommGrpCat]
  [∀ (X : C) (Y : Over X), HasSheafify ((J.over X).over Y) AddCommGrpCat] in
/-- Being of finite type is a local property: if the restrictions of `M` to a family of
objects covering the terminal object are of finite type, then so is `M`. This is the
step "since being of finite type is a local property it suffices to check this in a
neighbourhood of any `x ∈ U`" in the proof of Stacks 30.9.1 (tag 01XZ). -/
lemma SheafOfModules.IsFiniteType.of_coversTop
    (M : SheafOfModules.{u} R) {ι : Type u} (Y : ι → C) (hY : J.CoversTop Y)
    [h : ∀ i, (M.over (Y i)).IsFiniteType] :
    M.IsFiniteType := by
  have hex (i : ι) := SheafOfModules.IsFiniteType.exists_localGeneratorsData (M.over (Y i))
  choose D hD using hex
  refine ⟨⟨LocalGeneratorsData.bind M Y hY D, ⟨fun ij ↦ ⟨?_⟩⟩⟩⟩
  haveI := (hD ij.1).isFiniteType ij.2
  exact inferInstanceAs (Finite ((D ij.1).generators ij.2).I)

end

