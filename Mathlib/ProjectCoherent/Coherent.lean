open CategoryTheory Limits TopologicalSpace

/-- The affine open subsets contained in an open `U` cover the terminal object of the
localized Zariski site `Over U`. This implements the reduction "it suffices to check
this in a neighbourhood of any `x ∈ U`, thus we may assume `U = Spec(A)` is affine" in
the proof of Stacks 30.9.1 (tag 01XZ), using that the affine opens form a basis of the
topology of a scheme. -/
lemma AlgebraicGeometry.Scheme.coversTop_over_affineOpens (X : Scheme.{u}) (U : X.Opens) :
    ((Opens.grothendieckTopology X).over U).CoversTop
      (fun V : {V : X.affineOpens // (V : X.Opens) ≤ U} ↦ Over.mk (homOfLE V.2)) := by
  intro W
  rw [GrothendieckTopology.mem_over_iff, Opens.mem_grothendieckTopology]
  intro x hx
  obtain ⟨V, hV, hxV, hVW⟩ := Opens.isBasis_iff_nbhd.mp X.isBasis_affineOpens hx
  refine ⟨V, homOfLE hVW, ?_, hxV⟩
  exact ⟨Over.mk (homOfLE (hVW.trans (leOfHom W.hom))), Over.homMk (homOfLE hVW),
    𝟙 V, ⟨⟨⟨V, hV⟩, hVW.trans (leOfHom W.hom)⟩, ⟨Over.homMk (𝟙 V)⟩⟩,
    (CategoryTheory.Category.id_comp _).symm⟩

/-- Affine local step in the proof of (3) ⇒ (1) of Stacks 30.9.1 (tag 01XZ): if `V ≤ U`
is an affine open of the locally Noetherian scheme `X` and `φ : ⊕_{i ∈ I} 𝒪_U ⟶ 𝒪_U`
is a morphism with `I` finite, then the restriction of `kernel φ` to `V` is of finite
type.

Proof sketch, following the Stacks project: the ring `A := Γ(X, V)` is Noetherian since
`X` is locally Noetherian (Properties, Lemma 28.5.2; in mathlib this is
`IsLocallyNoetherian.component_noetherian`). The kernel `K` of the corresponding linear
map `⊕_{i ∈ I} A → A` is a finite `A`-module because `A` is Noetherian (Algebra,
Lemma 10.51.1; in mathlib, `IsNoetherian.noetherian` and `Module.Finite.iff_fg`). Since
the functor `~` is exact (Schemes, Lemma 26.5.4), the restriction of `kernel φ` to `V`
is `K~`, which is of finite type by Properties, Lemma 28.17.1. The comparison between
sheaves of modules on the localized Zariski site over `V` and modules over `Γ(X, V)`
(`ModuleCat.tilde`, in `Mathlib.AlgebraicGeometry.Modules.Tilde`) does not yet provide
exactness of `~` nor the finite type transfer, whence the `sorry`. -/
lemma isFiniteType_over_kernel_of_isAffineOpen (U : X.Opens) {I : Type u} [Finite I]
    (φ : SheafOfModules.free I ⟶ (SheafOfModules.unit X.ringCatSheaf).over U)
    {V : X.Opens} (hV : IsAffineOpen V) (hVU : V ≤ U) :
    ((kernel φ).over (Over.mk (homOfLE hVU))).IsFiniteType := by
  -- `A := Γ(X, V)` is Noetherian (Properties, Lemma 28.5.2)
  have _hA : IsNoetherianRing Γ(X, V) := IsLocallyNoetherian.component_noetherian ⟨V, hV⟩
  sorry

/-- Given an open `U ⊆ X` and a finite family of sections `fᵢ ∈ 𝒪_X(U)`, equivalently a
morphism `φ : ⊕_{i ∈ I} 𝒪_U ⟶ 𝒪_U` with `I` finite, the kernel of `φ` is of finite
type. This is the statement "we have to show: given any open `U ⊆ X` and any finite
collection of sections `fᵢ ∈ 𝒪_X(U)` the kernel of the map `⊕ 𝒪_U ⟶ 𝒪_U` is of finite
type" in the proof of (3) ⇒ (1) of Stacks 30.9.1 (tag 01XZ): finite type being a local
property, this follows from the affine case applied to an affine open cover of `U`. -/
lemma isFiniteType_kernel_freeToUnit (U : X.Opens) {I : Type u} [Finite I]
    (φ : SheafOfModules.free I ⟶ (SheafOfModules.unit X.ringCatSheaf).over U) :
    (kernel φ).IsFiniteType := by
  haveI (V : {V : X.affineOpens // (V : X.Opens) ≤ U}) :
      ((kernel φ).over (Over.mk (homOfLE V.2))).IsFiniteType :=
    isFiniteType_over_kernel_of_isAffineOpen X U φ V.1.2 V.2
  exact SheafOfModules.IsFiniteType.of_coversTop (kernel φ)
    (fun V : {V : X.affineOpens // (V : X.Opens) ≤ U} ↦ Over.mk (homOfLE V.2))
    (X.coversTop_over_affineOpens U)

/-- The structure sheaf of a locally Noetherian scheme, viewed as a module over itself,
is coherent. This is the main step of the implication (3) ⇒ (1) in Stacks 30.9.1
(tag 01XZ). -/
theorem isCoherent_unit : IsCoherent (SheafOfModules.unit X.ringCatSheaf) := by
  refine ⟨inferInstance, fun σ hσ i ↦ ?_⟩
  haveI := (hσ i).finite
  exact isFiniteType_kernel_freeToUnit X (σ.X i) (σ.sections i).π

/-- Coherence of sheaves of modules is a local property: if the restrictions of `M` to
the members of a family of opens covering `X` are coherent, then `M` is coherent. This
is implicit in the proof of Modules, Lemma 17.12.5 (tag 01BZ): coherence is verified
locally (the defining conditions of coherence in Modules, Definition 17.12.1 are local).

The finite type part is `SheafOfModules.IsFiniteType.of_coversTop`. The kernel condition
also localizes by the same lemma, but transporting the kernel of a map from a finite
free module along the restriction functors between the iterated slice sites
(`Over (σ.X i)` over `Over (W j)`) is not yet formalized, whence the `sorry`. -/
lemma isCoherent_of_coversTop (X : Scheme.{u}) (M : SheafOfModules X.ringCatSheaf)
    {ι : Type u} (W : ι → X.Opens) (hW : (Opens.grothendieckTopology X).CoversTop W)
    [h : ∀ j, IsCoherent (M.over (W j))] : IsCoherent M := by
  constructor
  · haveI : ∀ j, (M.over (W j)).IsFiniteType := fun j ↦ (h j).finiteType
    exact SheafOfModules.IsFiniteType.of_coversTop M W hW
  · intro σ hσ i
    sorry

set_option maxHeartbeats 800000 in
-- Synthesizing the `HasWeakSheafify`/`WEqualsLocallyBijective` instances for the
-- iterated slice sites appearing in `IsCoherent (cokernel d)` is slow, as are the
-- definitional-equality checks they entail.
set_option synthInstance.maxHeartbeats 400000 in
/-- Modules, Lemma 17.12.3 (tag 01BX) and Lemma 17.12.4 (tag 01BY): if the structure
sheaf is coherent then finite free modules are coherent (finite direct sums of coherent
modules are coherent), and the cokernel of a morphism of coherent modules is coherent.
Consequently, the cokernel of a morphism of finite free modules over the restriction of
`𝒪_X` to an open `W` is coherent. Both cited lemmas hold on arbitrary ringed spaces;
they are stated here in the combined form in which they are consumed in the proof of
Modules, Lemma 17.12.5 (tag 01BZ). -/
lemma isCoherent_cokernel_free (X : Scheme.{u}) (W : X.Opens)
    {ι ι' : Type u} [Finite ι] [Finite ι']
    (d : SheafOfModules.free (R := Sheaf.over X.ringCatSheaf W) ι ⟶
      SheafOfModules.free ι')
    (hO : IsCoherent (SheafOfModules.unit X.ringCatSheaf)) :
    IsCoherent (cokernel d) := by
  sorry

set_option maxHeartbeats 800000 in
-- Synthesizing the `HasWeakSheafify`/`WEqualsLocallyBijective` instances for the
-- iterated slice sites appearing in `IsCoherent (M.over (σ.X j))` is slow, as are the
-- definitional-equality checks they entail.
set_option synthInstance.maxHeartbeats 400000 in
omit [IsLocallyNoetherian X] in
/-- Modules, Lemma 17.12.5 (Stacks tag 01BZ): over a ringed space whose structure sheaf
is coherent, every module of finite presentation is coherent. This is the lemma quoted
as "By Modules, Lemma 17.12.5 it suffices to show that `𝒪_X` is coherent" in the proof
of (3) ⇒ (1) of Stacks 30.9.1 (tag 01XZ); it holds for arbitrary ringed spaces (no
Noetherian hypothesis) and is stated here for schemes.

Proof: choose a covering `W j` of `X` together with finite presentations
`⊕_{ι'} 𝒪 ⟶ ⊕_ι 𝒪 ⟶ M.over (W j) ⟶ 0`. Each `M.over (W j)` is then isomorphic to the
cokernel of a morphism of finite free modules, which is coherent by Modules 17.12.3 and
17.12.4 (`isCoherent_cokernel_free`). Since coherence is local
(`isCoherent_of_coversTop`), `M` is coherent. -/
theorem isCoherent_of_isFinitePresentation_of_isCoherent_unit
    (M : SheafOfModules X.ringCatSheaf) [M.IsFinitePresentation]
    (hO : IsCoherent (SheafOfModules.unit X.ringCatSheaf)) :
    IsCoherent M := by
  -- choose local finite presentations of `M`
  obtain ⟨σ, hσ⟩ := SheafOfModules.IsFinitePresentation.exists_quasicoherentData M
  -- each `M.over (σ.X j)` is a cokernel of a morphism of finite free modules,
  -- hence coherent by Modules 17.12.3 and 17.12.4
  haveI : ∀ j, IsCoherent (M.over (σ.X j)) := fun j ↦ by
    haveI := hσ.isFinite_presentation j
    exact isCoherent_of_iso
      (IsColimit.coconePointUniqueUpToIso (colimit.isColimit _)
        (σ.presentation j).isColimit)
      (isCoherent_cokernel_free X (σ.X j)
        ((SheafOfModules.freeHomEquiv _).symm (σ.presentation j).relations.s ≫
          kernel.ι (σ.presentation j).generators.π) hO)
  -- coherence is a local property
  exact isCoherent_of_coversTop X M σ.X σ.coversTop

end

theorem IsFinitePresentation_implies_Coherent (X : Scheme) [IsLocallyNoetherian X]
  (M : SheafOfModules X.ringCatSheaf) :
  M.IsFinitePresentation → IsCoherent M := by
  intro hM
  haveI := hM
  exact isCoherent_of_isFinitePresentation_of_isCoherent_unit X M (isCoherent_unit X)
