
module

public import Mathlib.Algebra.Category.ModuleCat.Sheaf.Quasicoherent

public import Mathlib.Algebra.Category.ModuleCat.Sheaf.Generators

universe u u' v'

variable {C : Type u'} [CategoryTheory.Category.{v', u'} C]
  {J : CategoryTheory.GrothendieckTopology C}
  {R : CategoryTheory.Sheaf J RingCat} (M : SheafOfModules R)
  [∀ (X : C), CategoryTheory.HasWeakSheafify (J.over X) AddCommGrpCat]
  [∀ (X : C), (J.over X).WEqualsLocallyBijective AddCommGrpCat]


/-- The data of local generators of a sheaf of modules is finite type if
each family of generators is finite type. -/
class LocalGeneratorsData.IsFiniteType (p : M.LocalGeneratorsData) : Prop where
  isFiniteType (i : p.I) : (p.generators i).IsFiniteType := by infer_instance

/-- A sheaf of modules is of finite type if locally, it is generated by finitely
many sections. -/
class IsFiniteType (M : SheafOfModules.{u} R) : Prop where
  exists_localGeneratorsData (M) :
    ∃ (σ : (M.LocalGeneratorsData.{u'})), σ.IsFiniteType

instance : ∀ (σ : (M.LocalGeneratorsData.{u'})), ∀ i, ∀ (X : CategoryTheory.Over (σ.X i)), CategoryTheory.HasWeakSheafify ((J.over (σ.X i)).over X) AddCommGrpCat := sorry

instance : ∀ (σ : (M.LocalGeneratorsData.{u'})), ∀ i, ∀ (X : CategoryTheory.Over (σ.X i)), ((J.over (σ.X i)).over X).WEqualsLocallyBijective AddCommGrpCat := sorry

/-- A sheaf of modules is of finite type if locally, it is generated by finitely
many sections. -/
class IsCoherent (M : SheafOfModules.{u} R) : Prop where
  finiteType : M.IsFiniteType
  forall_localGeneratorsData (M) : --todo: should we combine the foralls?
    ∀ (σ : (M.LocalGeneratorsData.{u'})), (∀ i, (σ.generators i).IsFiniteType) →
      ∀ i, ((CategoryTheory.Limits.kernel  (σ.generators i).π)).IsFiniteType

