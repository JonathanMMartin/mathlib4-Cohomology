/-- The type of sections which doesn't necessarily generate a sheaf of modules. -/
structure SheafOfModules.Sections where
  /-- the index type for the sections -/
  I : Type u
  /-- a family of sections which generate the sheaf of modules -/
  s : I → M.sections

/-- The data of generating sections of the restriction of a sheaf of modules
over a covering of the terminal object. -/
structure SheafOfModules.LocalSectionData where
  /-- the index type of the covering -/
  I : Type u
  /-- a family of objects which cover the terminal object -/
  X : I → C
  coversTop : J.CoversTop X
  /-- the data of sections of `M` over `X i` which generate `M.over (X i)` -/
  sections (i : I) : (M.over (X i)).Sections

/-- `σ : M.GeneratingSections` is finite type if the index type `σ.I` is finite. -/
class SheafOfModules.Sections.IsFiniteType (σ : M.Sections) : Prop where
  finite : Finite σ.I := by infer_instance

class SheafOfModules.LocalSectionData.IsFiniteType (p : M.LocalSectionData) : Prop where
  isFiniteType (i : p.I) : (p.sections i).IsFiniteType := by infer_instance

/-- The epimorphism `free σ.I ⟶ M` given by `σ : M.GeneratingSections`. -/
noncomputable abbrev SheafOfModules.Sections.π
    [CategoryTheory.HasWeakSheafify J AddCommGrpCat]
    [J.WEqualsLocallyBijective AddCommGrpCat]
    (σ : M.Sections) :=
  M.freeHomEquiv.symm σ.s

/-- A sheaf of modules is of finite type if locally, it is generated by finitely
many sections. -/
class IsCoherent (M : SheafOfModules.{u} R)
    [∀ (σ : (M.LocalSectionData.{u})), ∀ i, ∀ (X : CategoryTheory.Over (σ.X i)), CategoryTheory.HasWeakSheafify ((J.over (σ.X i)).over X) AddCommGrpCat]
    [∀ (σ : (M.LocalSectionData.{u})), ∀ i, ∀ (X : CategoryTheory.Over (σ.X i)), ((J.over (σ.X i)).over X).WEqualsLocallyBijective AddCommGrpCat] : Prop where
  finiteType : M.IsFiniteType
  forall_localSectionData (M) : --todo: should we combine the foralls?
    ∀ (σ : (M.LocalSectionData.{u})), (∀ i, (σ.sections i).IsFiniteType) →
      ∀ i, ((CategoryTheory.Limits.kernel  (σ.sections i).π)).IsFiniteType

variable (X : Scheme) [IsLocallyNoetherian X]
  (M : SheafOfModules X.ringCatSheaf)

lemma Coherent_implies_Quasicoherent (M : SheafOfModules.{u} R) :
  IsCoherent M → M.IsQuasicoherent :=
  by sorry

lemma ker_of_finite_type_morphism_is_finite_type {M N : SheafOfModules.{u} R} (φ : M ⟶ N) [M.IsFiniteType] [IsCoherent N] :
  (CategoryTheory.Limits.kernel φ).IsFiniteType := by sorry

#check SheafOfModules.free

lemma free_finite_module_is_finite_type (I : Type u) [Finite I] :
  SheafOfModules.free (J := J) (R := R) I |>.IsFiniteType := sorry

lemma pullback_coherent_is_coherent (M : SheafOfModules R) (σ : M.LocalSectionData) [IsCoherent M]:
  ∀ i : σ.I, IsCoherent (M.over (σ.X i)) :=
  by sorry

theorem Coherent_implies_WeakCoherent (X : Scheme) [IsLocallyNoetherian X]
  (M : SheafOfModules X.ringCatSheaf) :
  IsCoherent M → IsWeakCoherent X M := by
    intro h1
    constructor
    · apply Coherent_implies_Quasicoherent M
      exact h1
    · exact h1.finiteType
